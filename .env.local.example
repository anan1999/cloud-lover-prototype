# Copy this file to .env.local for local development.
# Do not commit real API keys.

PORT=8787
NODE_ENV=development

# Default route: Google Gemini first, Codex second. No mock in quality testing.
PROVIDER_ORDER=gemini,codex
ALLOWED_ORIGINS=
EXPOSE_DEBUG=1
ENABLE_PROVIDER_STATUS=1
DATABASE_URL=
ADMIN_EMAILS=admin@example.com

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.0-flash-lite,gemini-flash-lite-latest

# Codex provider
ENABLE_CODEX_PROVIDER=1
CODEX_BACKEND=api
CODEX_API_KEY=
CODEX_MODEL=gpt-5.5
CODEX_TIMEOUT_MS=60000

# Optional local CLI fallback, slower because every request starts a Codex process
CODEX_COMMAND=codex.exe
CODEX_WORKER_URL=
CODEX_WORKER_TOKEN=

# Security and routing
ENABLE_MOCK_FALLBACK=0
ENABLE_EXPERIMENTAL_PROVIDERS=0
CACHE_TTL_MS=120000
PROVIDER_COOLDOWN_MS=60000
PROVIDER_TIMEOUT_MS=60000
GEMINI_TIMEOUT_MS=12000
MOCK_FALLBACK_DELAY_MS=0
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
BODY_LIMIT_BYTES=65536
