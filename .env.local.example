# Copy this file to .env.local, then fill only the providers you want to use.
# Do not paste keys into chat.

PORT=8787

# Fast/free-ish providers first, Codex as local fallback, mock as final fallback.
PROVIDER_ORDER=gemini,nvidia,openrouter,groq,codex,mock

# Codex local provider
ENABLE_CODEX_PROVIDER=1
CODEX_COMMAND=C:\Users\hi\AppData\Local\OpenAI\Codex\bin\716dda49c14d31a0\codex.exe
CODEX_MODEL=gpt-5.4-mini
CODEX_TIMEOUT_MS=45000

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
OPENROUTER_MODELS=qwen/qwen3-next-80b-a3b-instruct:free,google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free,moonshotai/kimi-k2.6:free,nvidia/nemotron-3-nano-30b-a3b:free,liquid/lfm-2.5-1.2b-instruct:free

# NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_MODEL=google/gemma-3n-e2b-it

# OpenAI API, optional
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Routing behavior
CACHE_TTL_MS=120000
PROVIDER_COOLDOWN_MS=60000
PROVIDER_TIMEOUT_MS=12000
